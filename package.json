{
  "name": "codewiki-mcp",
  "version": "1.0.0",
  "description": "MCP server for CodeWiki - Get repository details, explanations, and code analysis",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "codewiki-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "codewiki:query": "tsx src/codewiki-cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "codewiki",
    "repository",
    "code-analysis",
    "github",
    "model-context-protocol",
    "claude",
    "cursor",
    "ai"
  ],
  "author": "R8-Devsin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R8-Devsin/codewiki-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/R8-Devsin/codewiki-mcp/issues"
  },
  "homepage": "https://github.com/R8-Devsin/codewiki-mcp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
